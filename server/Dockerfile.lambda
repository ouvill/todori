# syntax=docker/dockerfile:1
# Lambda deployment image. Before building, tool/prepare_lambda_extension.sh
# must place the pinned AWS Parameters and Secrets extension in .lambda/extensions.

FROM rust:slim@sha256:34fb2f168c432d421a09883c663b275b33cbb30f6b18642fbd09a684c6546d0e AS builder
WORKDIR /build

COPY Cargo.toml Cargo.lock rust-toolchain.toml ./
COPY core ./core
COPY app/rust ./app/rust
COPY cli ./cli
COPY mcp-server ./mcp-server
COPY server ./server
COPY xtask ./xtask

RUN cargo build --release -p taskveil-server --bins

FROM gcr.io/distroless/cc-debian12@sha256:7ee09f36862efbdbf70422db263e411c2618409ca46faa555bd5b636155307df AS runtime

COPY --from=public.ecr.aws/awsguru/aws-lambda-adapter:0.9.1@sha256:46d6625e68cbbdd2efab4a20245977664513f13ffef47915b000d431adcea0b4 /lambda-adapter /opt/extensions/lambda-adapter
COPY .lambda/extensions/AWSParametersAndSecretsLambdaExtension /opt/extensions/AWSParametersAndSecretsLambdaExtension
COPY --from=builder /build/target/release/taskveil-server /usr/local/bin/taskveil-server
COPY --from=builder /build/target/release/taskveil-migrate /usr/local/bin/taskveil-migrate

ENV PORT=8080 \
    PARAMETERS_SECRETS_EXTENSION_HTTP_PORT=2773
EXPOSE 8080

ENTRYPOINT ["/usr/local/bin/taskveil-server"]
